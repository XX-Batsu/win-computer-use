# .env.example — Copy this file to .env and fill in your values.
#
# This file is safe to commit to version control.
# The actual .env file is gitignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your real values

# ---------------------------------------------------------------------------
# ENGINE_SECRET
# A shared secret used to authenticate requests between the MCP server /
# scheduler and the Engine (FastAPI). Both sides must use the same value.
#
# Security: Generate a strong random secret before first use, for example:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never use the placeholder value in a real deployment.
# ---------------------------------------------------------------------------
ENGINE_SECRET=change-me-to-a-strong-random-secret

# ---------------------------------------------------------------------------
# ENGINE_URL
# Base URL of the Engine HTTP server. Override only if you are running the
# Engine on a non-default port or on a remote host.
# Default: http://127.0.0.1:8765
# ---------------------------------------------------------------------------
ENGINE_URL=http://127.0.0.1:8765
